{
  "name": "adhoc-lms-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:client": "npm install --prefix adhoc_test_lms",
    "install:server": "npm install --prefix lms_backend",
    "build:client": "npm run build --prefix adhoc_test_lms",
    "install-all": "npm run install:client && npm run install:server",
    "build-all": "npm run build:client",
    "build": "npm run build-all",
    "postinstall": "npm run install-all && npm run build-all",
    "start": "node lms_backend/server.js"
  }


}
